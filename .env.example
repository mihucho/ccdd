# 飞书Webhook配置
# 获取方法：
# 1. 在飞书中创建群组
# 2. 添加自定义机器人
# 3. 复制生成的webhook地址替换下面的URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_URL_HERE

# 通知配置
# 是否启用飞书通知 (true/false)
NOTIFICATION_ENABLED=true

# 是否启用声音提醒 (true/false)
SOUND_ENABLED=true

# Telegram Bot配置
# 获取方法：
# 1. 与 @BotFather 对话创建机器人，获取 token
# 2. 将机器人添加到频道/群组，或直接与机器人对话
# 3. 获取 chat_id (个人ID或频道ID，可通过 https://api.telegram.org/bot<TOKEN>/getUpdates 获取)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# 钉钉自定义机器人配置
# 获取方法：
# 1. 在钉钉中创建群组
# 2. 群设置 > 智能群助手 > 添加机器人 > 自定义（通过Webhook接入）
# 3. 安全设置推荐选择"加签"，复制密钥填入 DINGTALK_SECRET
# 4. 复制生成的webhook地址替换下面的URL
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_ACCESS_TOKEN_HERE
# 加签密钥（安全设置选择"加签"时必填）
DINGTALK_SECRET=your_secret_here

# 钉钉企业内部机器人配置（支持双向交互）
# 获取方法：
# 1. 登录钉钉开放平台 https://open-dev.dingtalk.com
# 2. 创建企业内部应用，开启机器人能力
# 3. 获取 AppKey 和 AppSecret
# 4. 配置消息目标：用户ID（单聊）或群会话ID（群聊）
DINGTALK_ROBOT_APP_KEY=your_app_key_here
DINGTALK_ROBOT_APP_SECRET=your_app_secret_here
# 机器人编码（默认与 AppKey 相同，一般无需单独设置）
# DINGTALK_ROBOT_CODE=your_robot_code_here
# 单聊通知的目标用户ID（逗号分隔，可通过钉钉管理后台获取）
DINGTALK_ROBOT_USER_IDS=user_id_1,user_id_2
# 群聊通知的群会话ID（通过机器人回调事件中的 conversationId 获取）
# DINGTALK_ROBOT_CONVERSATION_ID=your_conversation_id_here

# HTTP代理配置（可选）
# 如果需要通过代理访问Telegram API，请配置以下选项之一
# 支持的格式：
# - http://127.0.0.1:7890
# - http://proxy.example.com:8080
# - http://user:password@proxy.example.com:8080
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890